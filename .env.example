DB_PATH="/db/hookfy.db"
PORT=8080

# Docker Hub image reference used by docker-compose (ex.: your-user/hookfy:latest)
DOCKER_IMAGE=your-dockerhub-user/hookfy:latest

# Public port exposed by Nginx on the host
HTTP_PORT=80

# Server hostname used in nginx.conf (ex.: hookfy.example.com or _ for any)
SERVER_NAME=_

# ---------------------------------------------------------------------------
# GitHub Actions secrets (set these in the repository Settings > Secrets):
#   DOCKERHUB_USERNAME  -> your Docker Hub username
#   DOCKERHUB_TOKEN     -> a Docker Hub access token with Read/Write scope
# ---------------------------------------------------------------------------
